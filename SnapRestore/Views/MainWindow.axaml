<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SnapRestore.ViewModels"
        xmlns:controls="using:SnapRestore.Controls"
        x:Class="SnapRestore.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="700"
        Height="825"
        MaxWidth="700"
        MaxHeight="825"
        MinWidth="700"
        MinHeight="825"
        Icon="/Assets/Icons/SnapRestore.png"
        TransparencyLevelHint="None"
        UseLayoutRounding="True"
        Title="SnapRestore">

    <Border Padding="26" Classes="app">
        <StackPanel Spacing="22">

            <Grid Height="190"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="18">

                <Grid x:Name="MemoriesDropZone"
                      Cursor="Hand"
                      Opacity="{Binding MemoriesDropZoneOpacity}"
                      DragDrop.AllowDrop="True"
                      DragDrop.DragEnter="OnMemoriesDragEnter"
                      DragDrop.DragOver="OnMemoriesDragOver"
                      DragDrop.DragLeave="OnMemoriesDragLeave"
                      DragDrop.Drop="OnMemoriesDrop"
                      PointerEntered="OnMemoriesPointerEntered"
                      PointerExited="OnMemoriesPointerExited"
                      PointerPressed="OnMemoriesPointerPressed">

                    <Grid.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                        </Transitions>
                    </Grid.Transitions>

                    <Rectangle
                        RadiusX="18"
                        RadiusY="18"
                        Fill="Transparent"
                        Stroke="{Binding MemoriesDropZoneBorderBrush}"
                        StrokeThickness="2"
                        StrokeDashArray="1,3"
                        StrokeLineCap="Round"/>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False"
                                Spacing="12"
                                Margin="18">

                        <Viewbox Width="44"
                                 Height="44"
                                 HorizontalAlignment="Center">
                            <Canvas Width="48" Height="48">
                                <Path Fill="#FFA000"
                                      Data="M40,12H22l-4-4H8c-2.2,0-4,1.8-4,4v8h40v-4C44,13.8,42.2,12,40,12z"/>
                                <Path Fill="#FFCA28"
                                      Data="M40,12H8c-2.2,0-4,1.8-4,4v20c0,2.2,1.8,4,4,4h32c2.2,0,4-1.8,4-4V16C44,13.8,42.2,12,40,12z"/>
                            </Canvas>
                        </Viewbox>

                        <TextBlock Text="Memories folder"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Drop the Snapchat memories folder here"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Opacity="0.75"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Grid>

                <Grid Grid.Column="1"
                      x:Name="JsonDropZone"
                      Cursor="Hand"
                      Opacity="{Binding JsonDropZoneOpacity}"
                      DragDrop.AllowDrop="True"
                      DragDrop.DragEnter="OnJsonDragEnter"
                      DragDrop.DragOver="OnJsonDragOver"
                      DragDrop.DragLeave="OnJsonDragLeave"
                      DragDrop.Drop="OnJsonDrop"
                      PointerEntered="OnJsonPointerEntered"
                      PointerExited="OnJsonPointerExited"
                      PointerPressed="OnJsonPointerPressed">

                    <Grid.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                        </Transitions>
                    </Grid.Transitions>

                    <Rectangle
                        RadiusX="18"
                        RadiusY="18"
                        Fill="Transparent"
                        Stroke="{Binding JsonDropZoneBorderBrush}"
                        StrokeThickness="2"
                        StrokeDashArray="1,3"
                        StrokeLineCap="Round"/>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False"
                                Spacing="12"
                                Margin="18">

                        <TextBlock Text="{}{ }"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Memories JSON"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Drop the JSON file here"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Opacity="0.75"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Grid>

            </Grid>
            
            <Border Classes="card">
                <StackPanel Spacing="18">
                    <Grid>
                        <Grid
                              ColumnDefinitions="150,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="10">

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       Text="Export Summary"
                                       FontSize="18"
                                       FontWeight="SemiBold" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Memories folder:" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding FolderStatus}"
                                       Opacity="0.75" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Media files:" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding MemoriesCount}"
                                       Opacity="0.75" />

	                            <TextBlock Grid.Row="3" Grid.Column="0" Text="JSON file:" />
	                            <TextBlock Grid.Row="3"
	                                       Grid.Column="1"
	                                       Text="{Binding JsonStatus}"
	                                       Opacity="0.75" />

	                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Output:" />
	                            <TextBlock Grid.Row="4"
	                                       Grid.Column="1"
	                                       Text="{Binding OutputStatus}"
	                                       TextWrapping="Wrap"
	                                       Opacity="0.75" />
	                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="18">
                    <TextBlock Text="Processing Progress"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <Grid ColumnDefinitions="150,*" RowDefinitions="Auto" ColumnSpacing="20">
                        <StackPanel Spacing="8"
                                    HorizontalAlignment="Center">
                            <Grid Width="120"
                                  Height="120"
                                  ClipToBounds="True"
                                  Background="{DynamicResource Surface}">
                                <controls:CircularProgressRing Width="120"
                                                               Height="120"
                                                               Value="{Binding ProgressPercentage}"
                                                               StrokeThickness="9"
                                                               TrackBrush="{DynamicResource ProgressTrack}"
                                                               ProgressBrush="{DynamicResource AppYellow}"
                                                               FillBrush="{DynamicResource Surface}" />
                                <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0:0}%}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Grid>

                            <TextBlock Text="{Binding ProgressStatus}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Opacity="0.75" />
                        </StackPanel>

                        <Grid Grid.Column="1"
                              VerticalAlignment="Center"
                              RowDefinitions="Auto,Auto,Auto"
                              ColumnDefinitions="150,*"
                              RowSpacing="12">

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Files to process:" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FilesToProcess}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Processed:" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProcessedFiles}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Failed:" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FailedFiles}" />
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="24">
	            
	            <StackPanel Grid.Column="0" Spacing="10">

			            <Button Classes="secondary-button"
			                    HorizontalAlignment="Stretch"
			                    HorizontalContentAlignment="Center"
			                    Content="⬇  Select Output Folder"
			                    IsEnabled="{Binding CanChooseOutputFolder}"
			                    Click="OnSelectOutputFolder" />

		            <TextBlock Text="Choose where to save the processed export"
		                       HorizontalAlignment="Center"
		                       TextAlignment="Center"
		                       Opacity="0.75"/>

	            </StackPanel>

	            <StackPanel Grid.Column="1" Spacing="10">

		                    <Button Classes="primary-button"
		                            HorizontalAlignment="Stretch"
		                            HorizontalContentAlignment="Center"
		                            Content="{Binding PrimaryButtonText}"
		                            IsVisible="{Binding IsPrimaryActionVisible}"
		                            IsEnabled="{Binding CanUsePrimaryButton}"
		                            Command="{Binding GoCommand}" />

		                    <Button Classes="secondary-button"
		                            HorizontalAlignment="Stretch"
		                            HorizontalContentAlignment="Center"
		                            IsVisible="{Binding IsFolderActionVisible}"
		                            IsEnabled="{Binding CanUsePrimaryButton}"
		                            Command="{Binding GoCommand}">
			                    <StackPanel Orientation="Horizontal"
			                                Spacing="10"
			                                HorizontalAlignment="Center">
				                    <Viewbox Width="24"
				                             Height="24"
				                             VerticalAlignment="Center">
					                    <Canvas Width="48" Height="48">
						                    <Path Fill="#FFA000"
						                          Data="M40,12H22l-4-4H8c-2.2,0-4,1.8-4,4v8h40v-4C44,13.8,42.2,12,40,12z"/>
						                    <Path Fill="#FFCA28"
						                          Data="M40,12H8c-2.2,0-4,1.8-4,4v20c0,2.2,1.8,4,4,4h32c2.2,0,4-1.8,4-4V16C44,13.8,42.2,12,40,12z"/>
					                    </Canvas>
				                    </Viewbox>
				                    <TextBlock Text="Go to Folder"
				                               FontSize="18"
				                               FontWeight="SemiBold"
				                               VerticalAlignment="Center"/>
			                    </StackPanel>
		                    </Button>

                    <TextBlock Text="{Binding PrimaryButtonHelpText}"
                               HorizontalAlignment="Center"
                               Opacity="0.75"/>

                </StackPanel>

            </Grid>

        </StackPanel>
    </Border>
</Window>
